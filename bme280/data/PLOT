set title "Temperature in Celsius and Humidity (%) vs Time"
set xlabel "Time (hours)"
set ylabel "Temperature in Celsius"
set y2label "Humidity (%)"
set y2tics
set terminal png
set output 'dual_axis_plot_hours.png'

# Plot temperature on the left axis and humidity on the right axis
plot 'modified_data.txt' using 1:2 with lines title 'Temperature in Celsius', \
     'modified_data.txt' using 1:3 axes x1y2 with lines title 'Humidity (%)'
